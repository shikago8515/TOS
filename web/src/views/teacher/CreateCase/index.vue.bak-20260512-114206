const extractJsonFromText = (text: string) => {
  if (!text) return text

  const trimmed = text.trim()
  const codeFenceJsonMatch = trimmed.match(/```json\s*([\s\S]*?)\s*```/i)
  if (codeFenceJsonMatch?.[1]) {
    return codeFenceJsonMatch[1].trim()
  }

  const codeFenceMatch = trimmed.match(/```\s*([\s\S]*?)\s*```/)
  if (codeFenceMatch?.[1]) {
    return codeFenceMatch[1].trim()
  }

  const firstBrace = trimmed.indexOf('{')
  const lastBrace = trimmed.lastIndexOf('}')
  if (firstBrace >= 0 && lastBrace > firstBrace) {
    return trimmed.slice(firstBrace, lastBrace + 1)
  }

  return trimmed
}

const normalizeParsedOutput = (parsed: any) => {
  if (!parsed || typeof parsed !== 'object') return parsed

  if (parsed.mockData && typeof parsed.mockData === 'string') {
    try { parsed.mockData = JSON.parse(parsed.mockData) } catch (e) {}
  }
  if (parsed.taskList && typeof parsed.taskList === 'string') {
    try { parsed.taskList = JSON.parse(parsed.taskList) } catch (e) {}
  }

  return parsed
}

const tryParseAgentOutput = (content: any) => {
  try {
    if (content && typeof content === 'object') {
      parsedContent.value = normalizeParsedOutput(content)
      return
    }

    if (typeof content === 'string') {
      let normalized = content.trim()
      if (!normalized || normalized === '暂无输出内容') {
        parsedContent.value = null
        return
      }

      if (normalized.startsWith('"') && normalized.endsWith('"')) {
        normalized = JSON.parse(normalized)
      }

      const parsed = JSON.parse(extractJsonFromText(normalized))
      parsedContent.value = normalizeParsedOutput(parsed)
      return
    }
  } catch (e) {
    console.warn('解析Agent输出内容失败，将显示原始文本', e)
  }
  parsedContent.value = null
}


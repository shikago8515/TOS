<template>
  <div ref="layoutRef" class="create-case-layout" :class="{ 'is-resizing': resizing }">
    <!-- Left Panel: Configuration -->
    <section class="config-pane" :style="configPaneStyle">
      <ConfigPanel
        :form="form"
        :batch-form="batchForm"
        v-model:generation-mode="generationMode"
        v-model:use-workflow-mode="useWorkflowMode"
        :loading="loading"
        :loading-classes="loadingClasses"
        :loading-students="loadingStudents"
        :loading-courses="loadingCourses"
        :class-list="classList"
        :student-list="studentList"
        :course-list="courseList"
        v-model:selected-students="selectedStudents"
        :select-all="selectAll"
        :is-indeterminate="isIndeterminate"
        :popular-keywords="popularKeywords"
        :difficulty-options="difficultyOptions"
        :intent-detecting="intentDetecting"
        :intent-detected="intentDetected"
        :intent-effective="intentEffective"
        :intent-confidence="intentConfidence"
        :intent-override="intentOverride"
        @class-change="handleClassChange"
        @select-all="handleSelectAll"
        @toggle-intent-override="handleToggleIntentOverride"
        @clear-intent-override="handleClearIntentOverride"
        @reset="handleReset"
        @generate="handleGenerate"
      />
    </section>

    <div
      class="resize-handle"
      :class="{ active: resizing }"
      @mousedown="startResize"
      title="拖拽调整左右区域宽度"
    ></div>

    <!-- Right Panel: Preview Workspace -->
    <main class="preview-workspace">
      <header class="workspace-header">
        <div class="breadcrumbs">
          <el-icon><Monitor /></el-icon>
          <span class="divider">/</span>
          <span class="current">案例预览</span>
        </div>
        <div class="actions" v-if="canAbortGeneration">
          <el-button
            type="danger"
            plain
            size="small"
            :loading="abortingGeneration"
            @click="handleAbortGeneration"
          >中断生成</el-button>
        </div>
        <div class="actions" v-if="generatedCase && !showReviewPanel">
          <el-button type="primary" icon="Edit" circle @click="handleEditCase" title="编辑案例" />
          <el-button type="success" icon="Check" circle @click="handlePublish" title="发布案例" />
          <el-button type="warning" icon="Refresh" circle @click="handleRegenerateSingleCase" title="重新生成" />
        </div>
      </header>

      <div class="workspace-body custom-scrollbar">
        <!-- Workflow Progress State (Single Mode Only) -->
        <BatchProgressPanel
          v-if="showSingleWorkflowPanel"
          :batch-task-id="String(activeWorkflowTaskId || '')"
          :progress="singleWorkflowBatchProgress"
          :deliverable-mode="form.deliverableMode"
          @view-logs="handleViewWorkflowLogs"
          @view-agent-output="handleViewAgentOutput"
          @approve-checkpoint="handleApproveCheckpoint"
        />

        <!-- Batch Progress Panel (All Batch Modes) -->
        <BatchProgressPanel
          v-else-if="showBatchProgressPanel"
          :batch-task-id="currentBatchTaskId"
          :progress="batchGenerationProgress || {}"
          :deliverable-mode="form.deliverableMode"
          @view-logs="handleViewWorkflowLogs"
          @preview-case="handlePreviewCaseById"
          @view-agent-output="handleViewAgentOutput"
          @approve-checkpoint="handleApproveCheckpoint"
        />
        
        <!-- Normal Loading State (single mode or batch startup) -->
        <div v-else-if="loading" class="state-container loading">
          <div class="loader-animation">
            <div class="scanner"></div>
          </div>
          <h3 v-if="generationMode === 'single'">AI 正在构建实训场景</h3>
          <h3 v-else>批量生成进行中</h3>
          <p v-if="generationMode === 'single'">正在分析关键词、生成任务清单与模拟数据...</p>
          <p v-else>正在为 {{ batchGeneratingStudentCount }} 名学生生成个性化案例...</p>
          <div v-if="isAnalysisMode" class="analysis-progress-card">
            <div class="progress-title">分析任务生成进度</div>
            <el-progress
              :percentage="analysisProgressPercent"
              :stroke-width="12"
            />
            <div class="progress-desc">{{ analysisProgressText }}</div>
          </div>
        </div>

        <!-- Batch Review Panel -->
        <ReviewPanel
          v-else-if="showReviewPanel"
          :pending-cases="pendingCases"
          :loading-pending-cases="loadingPendingCases"
          :selected-case-ids="selectedCaseIds"
          :regenerating-case-id="regeneratingCaseId"
          @select-all="handleSelectAllCases"
          @select-case="handleSelectCase"
          @batch-approve="handleBatchApprove"
          @approve-all="handleApproveAll"
          @preview="handlePreviewCase"
          @approve="handleApproveCase"
          @regenerate="handleRegenerateCase"
        />

        <!-- Empty State -->
        <div v-else-if="!generatedCase" class="state-container empty">
          <div class="empty-illustration">
            <div class="icon-placeholder">
              <el-icon><Collection /></el-icon>
            </div>
          </div>
          <h3>开始您的创作</h3>
          <p>在左侧配置面板输入需求，AI 将为您生成专业的实训案例。</p>
        </div>

        <!-- Document Preview (A4 Paper Style) -->
        <CaseDocument
          v-else
          :generated-case="generatedCase"
          :difficulty-level="form.difficultyLevel"
          :estimated-hours="form.estimatedHours"
          :difficulty-options="difficultyOptions"
        />
      </div>
    </main>
    
    <CasePreviewDialog
      v-model="showPreviewDialog"
      :preview-case="previewCase"
      :difficulty-options="difficultyOptions"
      @approve="handleApproveCaseFromDialog"
    />
    
    <!-- Workflow Logs Dialog -->
    <WorkflowLogsDialog
      v-model="showWorkflowLogsDialog"
      :workflow-instance-id="selectedWorkflowInstanceId"
      :deliverable-mode="form.deliverableMode"
    />
    
    <AgentOutputDialog
      v-model="showAgentOutputDialog"
      :agent-output-data="agentOutputData"
      :parsed-content="parsedContent"
      :is-single-workflow-reviewing="isSingleWorkflowReviewing"
      @approve="handleApproveSingleCheckpoint"
    />

    <el-tour v-model="showGuideDialog" @close="closeGuideDialog" :mask="true" :z-index="9999">
      <el-tour-step title="欢迎使用智能案例构建中心">
        <div class="tour-step-content">
          <p>这里是基于多 Agent 协同工作流的案例生成引擎，为您提供全场景、个性化的教学案例生成体验。</p>
          <div class="tour-checkbox-wrapper">
            <el-checkbox v-model="guideDontShowToday">今日不再自动弹出</el-checkbox>
          </div>
        </div>
      </el-tour-step>
      <el-tour-step target=".core-blueprint-card" title="核心蓝图构建" placement="right">
        <div class="tour-step-content">
          <p>在这里定义实训的<strong>主题、难度</strong>与<strong>技术栈</strong>要求。</p>
          <p>右上角可灵活切换<strong>纯编码</strong>模式与<strong>完整实训</strong>（工程流）模式。</p>
        </div>
      </el-tour-step>
      <el-tour-step target=".teaching-dispatch-card" title="教学与千人千案分发" placement="right">
        <div class="tour-step-content">
          <p>您可以选择生成<strong>单一案例</strong>，或一键为全班生成自带差异化业务数据的<strong>千人千案</strong>。</p>
        </div>
      </el-tour-step>
      <el-tour-step target=".ai-enhance-card" title="智能增强与工作流" placement="right">
        <div class="tour-step-content">
          <p>展开后可补充<strong>教学意图提示词</strong>、绑定教材进行 <strong>RAG 知识对齐</strong>。</p>
          <p>同时支持开启关键节点的 <strong>多Agent审查机制</strong> 与干预拦截。</p>
        </div>
      </el-tour-step>
      <el-tour-step target=".btn-submit" title="一键生成" placement="top">
        <div class="tour-step-content">
          <p>配置完成后，点击这里即可启动多 Agent 联合生成引擎！</p>
        </div>
      </el-tour-step>
    </el-tour>

    <el-dialog
      v-model="showGenerationNoticeDialog"
      title="生成提示"
      width="460px"
      :close-on-click-modal="false"
    >
      <p class="generation-notice-text">{{ generationNoticeText }}</p>
      <p class="generation-notice-text sub">预计队列并发上限（当前50），超出后将排队执行。</p>
      <template #footer>
        <el-button @click="handleCancelGenerationNotice">取消</el-button>
        <el-button type="primary" @click="handleConfirmGenerationNotice">我知道了，开始生成</el-button>
      </template>
    </el-dialog>
  </div>
</template>

<script setup lang="ts">
import { reactive, ref, onMounted, onUnmounted, watch, computed } from 'vue'
import { ElMessage, ElMessageBox } from 'element-plus'
import { Monitor, Collection } from '@element-plus/icons-vue'
import { useRouter } from 'vue-router'
import { generateCase, publishCase, generateCasesForClass, generateNonCodeCase, generateNonCodeCasesForClass, generateCaseWithWorkflow, generateCasesWithWorkflowBatch, generatePublicCasesWithWorkflowBatch, getCaseDetail, cancelWorkflow, detectNonCodeIntent, getWorkflowByCaseDifficulty } from '@/api/teacher/case'
import { getCreateCaseGuidePreference, updateCreateCaseGuidePreference } from '@/api/user'
import { getMyCourses } from '@/api/teacher/course'
import { getMyClasses, getClassStudents } from '@/api/teacher/class'
import { useCreateCasePolling } from './composables/useCreateCasePolling.js'
import { useCreateCaseReview } from './composables/useCreateCaseReview.js'
import { mapDeliverableModeToWorkflowMode, mapNumericDifficultyToWorkflowLevel } from '../Workflow/workflowModes'

import ConfigPanel from './ConfigPanel.vue'
import ReviewPanel from './ReviewPanel.vue'
import CaseDocument from './CaseDocument.vue'
import BatchProgressPanel from './BatchProgressPanel.vue'
import WorkflowLogsDialog from './WorkflowLogsDialog.vue'
import CasePreviewDialog from './CasePreviewDialog.vue'
import AgentOutputDialog from './AgentOutputDialog.vue'

const router = useRouter()
const layoutRef = ref<HTMLElement | null>(null)

const loading = ref(false)
const generatedCase = ref<any>(null)
const showGuideDialog = ref(false)
const guideDontShowToday = ref(false)
const showGenerationNoticeDialog = ref(false)
const pendingGenerateAction = ref<null | (() => Promise<void> | void)>(null)
const courseList = ref<any[]>([])
const loadingCourses = ref(false)
const abortingGeneration = ref(false)
const analysisSingleProgress = ref(0)
let analysisSingleProgressTimer: number | null = null
const analysisSingleTaskStatus = ref('PENDING')
const analysisSingleTaskBackendPercent = ref(0)
const analysisBatchTaskStatus = ref('PENDING')
const analysisWorkflowStatus = ref('')
const analysisWorkflowState = ref('')
const intentDetecting = ref(false)
const intentDetected = ref<'IMPLEMENTATION_LAB' | 'DATA_ANALYSIS'>('DATA_ANALYSIS')
const intentEffective = ref<'IMPLEMENTATION_LAB' | 'DATA_ANALYSIS'>('DATA_ANALYSIS')
const intentConfidence = ref(0)
const intentOverride = ref('')
let detectIntentTimer: number | null = null

const PANEL_MIN_WIDTH = 360
const PANEL_DEFAULT_WIDTH = 430
const PANEL_MAX_RATIO = 0.56
const resizing = ref(false)
const configPaneWidth = ref(PANEL_DEFAULT_WIDTH)

const resolveMaxPaneWidth = () => {
  const containerWidth = layoutRef.value?.clientWidth || window.innerWidth
  return Math.max(460, Math.floor(containerWidth * PANEL_MAX_RATIO))
}

const clampPaneWidth = (value: number) => {
  const maxWidth = resolveMaxPaneWidth()
  return Math.max(PANEL_MIN_WIDTH, Math.min(Math.round(value), maxWidth))
}

const configPaneStyle = computed(() => ({
  width: `${configPaneWidth.value}px`
}))

const handleResizeMove = (event: MouseEvent) => {
  if (!resizing.value || !layoutRef.value) return
  const rect = layoutRef.value.getBoundingClientRect()
  const nextWidth = event.clientX - rect.left
  configPaneWidth.value = clampPaneWidth(nextWidth)
}

const stopResize = () => {
  if (!resizing.value) return
  resizing.value = false
  document.body.style.cursor = ''
  document.body.style.userSelect = ''
  window.removeEventListener('mousemove', handleResizeMove)
  window.removeEventListener('mouseup', stopResize)
}

const startResize = () => {
  resizing.value = true
  document.body.style.cursor = 'col-resize'
  document.body.style.userSelect = 'none'
  window.addEventListener('mousemove', handleResizeMove)
  window.addEventListener('mouseup', stopResize)
}

// Workflow state
const useWorkflowMode = ref(false)
const showWorkflowProgress = ref(false)
const activeWorkflowTaskId = ref<string | null>(null)
const workflowStatus = ref<'pending' | 'processing' | 'completed' | 'failed' | 'reviewing' | 'error'>('pending')
const workflowCurrentStage = ref('INIT')
const workflowSteps = ref<any[]>([])
const workflowLogs = ref<any[]>([])
const workflowError = ref('')
// 批量生成相关状态
const generationMode = ref<'single' | 'batch'>('single')
const classList = ref<any[]>([])
const studentList = ref<any[]>([])
const selectedStudents = ref<number[]>([])
const selectAll = ref(false)
const isIndeterminate = ref(false)
const loadingClasses = ref(false)
const loadingStudents = ref(false)
const batchGenerationProgress = ref<any>(null)
const batchForm = reactive({
  classId: null
})

// 审核相关状态
const showReviewPanel = ref(false)
const pendingCases = ref<any[]>([])
const loadingPendingCases = ref(false)
const currentBatchTaskId = ref<string>('')
const selectedCaseIds = ref<number[]>([])
const regeneratingCaseId = ref<number | null>(null)
const previewCase = ref<any>(null)
const showPreviewDialog = ref(false)
const showWorkflowLogsDialog = ref(false)
const selectedWorkflowInstanceId = ref<number | null>(null)

const batchGeneratingStudentCount = computed(() => {
  return batchGenerationProgress.value?.totalCount
    || batchGenerationProgress.value?.totalStudents
    || selectedStudents.value.length
    || 0
})

const isAnalysisMode = computed(() => form.deliverableMode === 'NON_CODE')
const workflowModeActive = computed(() => isAnalysisMode.value || useWorkflowMode.value)

const generationParallelCount = computed(() => {
  if (generationMode.value === 'batch') {
    return Number(selectedStudents.value.length || 0)
  }

  if (workflowModeActive.value && generationMode.value === 'single') {
    return Number(form.numVersions || 1)
  }

  return 1
})

const generationNoticeText = computed(() => {
  const parallelCount = Number(generationParallelCount.value || 1)
  if (parallelCount >= 10) {
    return `正在并行生成 ${parallelCount} 个案例，耗时较长：请耐心等待。`
  }
  return `正在并行生成 ${parallelCount} 个案例，总耗时约为3-5分钟。`
})

const canAbortGeneration = computed(() => {
  return loading.value && !generatedCase.value && !showReviewPanel.value
})

const openGenerationNotice = (action: () => Promise<void> | void) => {
  pendingGenerateAction.value = action
  showGenerationNoticeDialog.value = true
}

const handleConfirmGenerationNotice = async () => {
  const action = pendingGenerateAction.value
  showGenerationNoticeDialog.value = false
  pendingGenerateAction.value = null
  if (!action) return
  await action()
}

const handleCancelGenerationNotice = () => {
  showGenerationNoticeDialog.value = false
  pendingGenerateAction.value = null
}

const loadGuidePreference = async () => {
  try {
    const response = await getCreateCaseGuidePreference()
    const hideToday = !!response?.data?.hideToday
    setTimeout(() => {
      showGuideDialog.value = !hideToday
    }, 300)
    guideDontShowToday.value = false
  } catch (error) {
    setTimeout(() => {
      showGuideDialog.value = true
    }, 300)
  }
}

const closeGuideDialog = async () => {
  try {
    await updateCreateCaseGuidePreference({
      hideToday: !!guideDontShowToday.value
    })
  } catch (error) {
    console.warn('保存创建案例引导偏好失败', error)
  } finally {
    showGuideDialog.value = false
  }
}

const showSingleWorkflowPanel = computed(() => {
  return workflowModeActive.value
    && generationMode.value === 'single'
    && (showWorkflowProgress.value || !!activeWorkflowTaskId.value)
    && (loading.value || workflowStatus.value === 'reviewing' || workflowStatus.value === 'processing' || workflowStatus.value === 'error')
})

const stageProgressMap: Record<string, number> = {
  INIT: 0,
  INPUT_PARSE: 12,
  GENERATION: 28,
  STRUCTURING: 45,
  VALIDATION: 62,
  DATA_GENERATION: 78,
  REVIEW: 90,
  PUBLISH: 96,
  COMPLETED: 100
}

const analysisSingleStatusDescMap: Record<string, string> = {
  PENDING: '排队中：正在接收分析任务请求',
  PROCESSING: '解析需求：正在构建分析任务',
  COMPLETED: '生成结果：分析任务案例已完成',
  SUCCESS: '生成结果：分析任务案例已完成',
  FAILED: '生成失败：请调整关键词后重试'
}

const analysisBatchStatusDescMap: Record<string, string> = {
  PENDING: '排队中：正在准备班级批量任务',
  PROCESSING: '构建任务：正在为学生生成分析案例',
  COMPLETED: '生成结果：批量分析案例已完成',
  SUCCESS: '生成结果：批量分析案例已完成',
  PARTIAL_SUCCESS: '生成结果：批量任务部分完成',
  FAILED: '生成失败：批量任务执行失败'
}

const analysisWorkflowStateDescMap: Record<string, string> = {
  INIT: '初始化：正在创建工作流实例',
  INPUT_PARSE: '解析需求：正在理解关键词与目标',
  GENERATION: '构建任务：正在生成分析任务主体',
  STRUCTURING: '结构整理：正在组织案例内容',
  VALIDATION: '质量校验：正在检查结果完整性',
  DATA_GENERATION: '生成结果：正在补全数据与输出',
  REVIEW: '人工审核：等待教师确认',
  PUBLISH: '发布准备：正在收尾处理',
  COMPLETED: '生成结果：工作流已完成'
}

const stopAnalysisSingleProgress = (reset = false) => {
  if (analysisSingleProgressTimer) {
    window.clearInterval(analysisSingleProgressTimer)
    analysisSingleProgressTimer = null
  }
  if (reset) {
    analysisSingleProgress.value = 0
  }
}

const startAnalysisSingleProgress = () => {
  stopAnalysisSingleProgress(true)
  analysisSingleProgress.value = 10
  analysisSingleProgressTimer = window.setInterval(() => {
    if (analysisSingleProgress.value >= 92) {
      stopAnalysisSingleProgress(false)
      return
    }
    analysisSingleProgress.value = Math.min(92, analysisSingleProgress.value + 4)
  }, 1200)
}

const singleWorkflowReviewSnapshot = ref<any>(null)

const singleWorkflowBatchProgress = computed(() => {
  const status = workflowStatus.value
  const isReviewing = status === 'reviewing'
  const isError = status === 'error'
  const isCompleted = status === 'completed'
  const workflowInstanceId = activeWorkflowTaskId.value ? Number(activeWorkflowTaskId.value) : 0
  const progressPercent = isCompleted
    ? 100
    : (stageProgressMap[workflowCurrentStage.value] ?? (status === 'processing' ? 20 : 0))

  const snapshot = singleWorkflowReviewSnapshot.value || {}
  return {
    totalStudents: 1,
    generatedCount: isCompleted ? 1 : 0,
    runningCount: isCompleted || isError ? 0 : 1,
    reviewingCount: isReviewing ? 1 : 0,
    progressPercent,
    studentProgress: [
      {
        studentId: 1,
        studentName: '单案例工作流',
        studentNo: workflowInstanceId ? `#${workflowInstanceId}` : '#-',
        avatar: '',
        status: isCompleted ? 'SUCCESS' : (isError ? 'FAILED' : 'RUNNING'),
        currentState: workflowCurrentStage.value,
        progressPercentage: progressPercent,
        needsReview: isReviewing,
        reviewingAgent: snapshot.reviewingAgent || snapshot.agentName || '未知Agent',
        reviewMessage: snapshot.reviewMessage || '',
        currentAgentOutput: snapshot.currentAgentOutput || snapshot.content || '',
        workflowInstanceId,
        errorMessage: isError ? workflowError.value : ''
      }
    ]
  }
})

const showBatchProgressPanel = computed(() => {
  return loading.value && !!batchGenerationProgress.value && (
    generationMode.value === 'batch' ||
    (workflowModeActive.value && generationMode.value === 'single' && Number(form.numVersions || 1) > 1)
  )
})

const analysisProgressPercent = computed(() => {
  if (!isAnalysisMode.value || !loading.value) {
    return 0
  }

  if (generationMode.value === 'batch') {
    const batchPercent = Number(batchGenerationProgress.value?.progressPercent || 0)
    return Math.max(5, Math.min(99, batchPercent || 5))
  }

  if (workflowModeActive.value) {
    const workflowStage = analysisWorkflowState.value || workflowCurrentStage.value
    const workflowPercent = Number(stageProgressMap[workflowStage] ?? 15)
    return Math.max(8, Math.min(99, workflowPercent))
  }

  const backendPercent = Number(analysisSingleTaskBackendPercent.value || 0)
  if (backendPercent > 0) {
    return Math.max(8, Math.min(99, backendPercent))
  }
  return Math.max(8, Math.min(99, analysisSingleProgress.value))
})

const analysisProgressText = computed(() => {
  const buildStageText = (code: string, desc: string) => {
    return `状态：${code || 'UNKNOWN'} · ${desc}`
  }

  if (generationMode.value === 'batch') {
    const code = String(analysisBatchTaskStatus.value || batchGenerationProgress.value?.status || 'PENDING').toUpperCase()
    const baseDesc = analysisBatchStatusDescMap[code] || '处理中：正在执行批量分析任务'
    const completed = Number(batchGenerationProgress.value?.completedCount || batchGenerationProgress.value?.generatedCount || 0)
    const total = Number(batchGenerationProgress.value?.totalCount || batchGenerationProgress.value?.totalStudents || 0)
    const suffix = total > 0 ? `（${completed}/${total}）` : ''
    return buildStageText(code, `${baseDesc}${suffix}`)
  }

  if (workflowModeActive.value) {
    const code = String(analysisWorkflowStatus.value || workflowStatus.value || 'PROCESSING').toUpperCase()
    const stateCode = String(analysisWorkflowState.value || workflowCurrentStage.value || 'INPUT_PARSE').toUpperCase()
    const stateDesc = analysisWorkflowStateDescMap[stateCode] || '处理中：工作流执行中'
    return buildStageText(`${code}/${stateCode}`, stateDesc)
  }

  const code = String(analysisSingleTaskStatus.value || 'PENDING').toUpperCase()
  const desc = analysisSingleStatusDescMap[code] || '处理中：正在生成分析任务案例'
  return buildStageText(code, desc)
})

const popularKeywords = [
  'Spring Boot', 'Vue3', '电商系统', '数据分析', '微服务', 'Redis', 'MySQL优化'
]

const difficultyOptions = [
  { value: 1, label: '初级', icon: 'Star' },
  { value: 2, label: '中级', icon: 'Connection' },
  { value: 3, label: '高级', icon: 'Trophy' }
]

const form = reactive({
  keywords: '',
  trainingTopic: '',
  techStackRequirements: [],
  datasetScale: 10,
  storyStyle: '',
  difficultyLevel: 2,
  estimatedHours: 3,
  deliverableMode: 'NON_CODE',
  courseId: null,
  numVersions: 1,
  // 教材RAG相关字段
  textbookId: null,
  chapterIds: [],
  isFullTextbook: false,
  knowledgePoints: [],
  learningObjectives: [],
  // Agent工作流相关配置
  enableWorkflow: false, // 是否启用工作流模式
  enableCheckpoints: true // 是否启用检查点审核（仅当enableWorkflow=true时生效）
})

const buildKeywordFallbackText = () => {
  return [
    String(form.trainingTopic || '').trim(),
    Array.isArray(form.techStackRequirements) ? form.techStackRequirements.join('、') : '',
    String(form.storyStyle || '').trim(),
    form.deliverableMode === 'NON_CODE' ? '完整实训案例' : '纯编码实战'
  ].filter(Boolean).join('，')
}

const resolveGenerationIntentText = () => {
  const topicContext = buildKeywordFallbackText()
  const keywordContext = String(form.keywords || '').trim()
  if (!topicContext) return keywordContext
  if (!keywordContext) return topicContext
  return `${topicContext}；补充约束：${keywordContext}`
}

const detectKeywordTopicConflict = () => {
  const topicText = `${String(form.trainingTopic || '').trim()} ${String(form.storyStyle || '').trim()}`.toLowerCase()
  const keywordsText = String(form.keywords || '').trim().toLowerCase()
  if (!topicText || !keywordsText) {
    return ''
  }

  const domainGroups = [
    { name: '食堂餐饮', tokens: ['食堂', '餐饮', '点餐', '菜品', '档口', 'canteen', 'dish'] },
    { name: '宠物健康', tokens: ['宠物', '疫苗', '宠物医院', 'pet', 'vaccine'] },
    { name: '图书交易', tokens: ['图书', '书店', '二手书', 'bookstore', 'book'] },
    { name: '医疗门诊', tokens: ['医院', '门诊', '患者', '挂号', 'medical', 'clinic'] },
    { name: '电商零售', tokens: ['电商', '商城', '购物车', '订单', 'ecommerce', 'retail'] },
    { name: '校园教务', tokens: ['校园', '教务', '选课', '成绩', 'student', 'course'] }
  ]

  const matchedTopicGroups = domainGroups
    .filter(group => group.tokens.some(token => topicText.includes(token)))
    .map(group => group.name)
  const matchedKeywordGroups = domainGroups
    .filter(group => group.tokens.some(token => keywordsText.includes(token)))
    .map(group => group.name)

  if (!matchedTopicGroups.length || !matchedKeywordGroups.length) {
    return ''
  }

  const hasOverlap = matchedKeywordGroups.some(group => matchedTopicGroups.includes(group))
  if (hasOverlap) {
    return ''
  }

  return `检测到主题与补充约束可能冲突：主题偏向「${matchedTopicGroups[0]}」，补充内容偏向「${matchedKeywordGroups[0]}」。请统一后再提交。`
}


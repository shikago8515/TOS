const runDetectIntent = async (immediate = false) => {
  if (!isAnalysisMode.value) return
  const keywords = resolveGenerationIntentText()
  if (!keywords) {
    intentDetected.value = 'DATA_ANALYSIS'
    intentEffective.value = intentOverride.value === 'IMPLEMENTATION_LAB' ? 'IMPLEMENTATION_LAB' : 'DATA_ANALYSIS'
    intentConfidence.value = 0
    return
  }

  const execute = async () => {
    try {
      intentDetecting.value = true
      const res = await detectNonCodeIntent({
        keywords,
        intentOverride: intentOverride.value || undefined
      })
      const data = res?.data || {}
      intentDetected.value = data.detectedIntent === 'IMPLEMENTATION_LAB' ? 'IMPLEMENTATION_LAB' : 'DATA_ANALYSIS'
      intentEffective.value = data.effectiveIntent === 'IMPLEMENTATION_LAB' ? 'IMPLEMENTATION_LAB' : 'DATA_ANALYSIS'
      intentConfidence.value = Number(data.confidence || 0)
    } catch (e) {
      intentDetected.value = 'DATA_ANALYSIS'
      intentEffective.value = intentOverride.value === 'IMPLEMENTATION_LAB' ? 'IMPLEMENTATION_LAB' : 'DATA_ANALYSIS'
      intentConfidence.value = 0
    } finally {
      intentDetecting.value = false
    }
  }

  if (immediate) {
    if (detectIntentTimer) {
      window.clearTimeout(detectIntentTimer)
      detectIntentTimer = null
    }
    await execute()
    return
  }

  if (detectIntentTimer) {
    window.clearTimeout(detectIntentTimer)
  }
  detectIntentTimer = window.setTimeout(() => {
    execute()
  }, 450)
}


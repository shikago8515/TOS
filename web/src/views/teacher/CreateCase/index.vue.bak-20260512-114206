      if (!batchForm.classId || selectedStudents.value.length === 0 || !resolveGenerationIntentText()) {
         if (!batchForm.classId) ElMessage.warning('请选择班级')
         else if (selectedStudents.value.length === 0) ElMessage.warning('请至少选择一个学生')
         else ElMessage.warning('请至少填写实训主题、技术栈、背景风格或补充需求描述中的一项')
         return
       }
      await handleWorkflowBatchGenerate()
    } else {
      await handleWorkflowGenerate()
    }
    return
  }

  if (generationMode.value === 'batch') {
    await handleGenerateBatch()
    return
  }
  
  if (!resolveGenerationIntentText()) {
    ElMessage.warning('请至少填写实训主题、技术栈、背景风格或补充需求描述中的一项')
    return
  }
  
  loading.value = true
  showReviewPanel.value = false
  generatedCase.value = null
  if (isAnalysisMode.value) {
    analysisSingleTaskStatus.value = 'PENDING'
    analysisSingleTaskBackendPercent.value = 0
    startAnalysisSingleProgress()
  }
  
  try {
    const payload: any = buildGenerationPayload({
      type: 1 // 单一生成默认为公共案例
    })
    if (isAnalysisMode.value && intentOverride.value) {
      payload.intentOverride = intentOverride.value
    }
    saveLastSingleGenerateSnapshot({
      type: isAnalysisMode.value ? 'analysis-single' : 'code-single',
      payload
    })
    const response = isAnalysisMode.value
      ? await generateNonCodeCase(payload)
      : await generateCase(payload)
    // 后端返回任务 ID，需要轮询查询结果
    const taskId = response.data.taskId
    ElMessage.success('案例生成已启动，正在处理中...')
    saveProgressState({
      generationMode: 'single',
      useWorkflowMode: false,
      singleTaskId: taskId
    })
    
    // 轮询查询任务状态
    pollTaskProgress(taskId)
  } catch (error: any) {
    ElMessage.error(error.message || '案例生成失败')
    loading.value = false
    stopAnalysisSingleProgress(true)
  }
}

const handleGenerate = () => {
  openGenerationNotice(executeGenerate)
}

const resetGenerationRuntimeState = () => {
  loading.value = false
  showWorkflowProgress.value = false
  workflowStatus.value = 'pending'
  workflowCurrentStage.value = 'INIT'
  workflowSteps.value = []
  workflowLogs.value = []
  workflowError.value = ''
  activeWorkflowTaskId.value = null
  currentBatchTaskId.value = ''
  batchGenerationProgress.value = null
  singleWorkflowReviewSnapshot.value = null
  analysisSingleTaskStatus.value = 'PENDING'
  analysisSingleTaskBackendPercent.value = 0
  analysisBatchTaskStatus.value = 'PENDING'
  analysisWorkflowStatus.value = ''
  analysisWorkflowState.value = ''
  stopAnalysisSingleProgress(true)
}

const handleAbortGeneration = async () => {
  if (!canAbortGeneration.value || abortingGeneration.value) return

  try {
    await ElMessageBox.confirm(
      '中断后当前生成流程将停止，确定继续吗？',
      '确认中断',
      {
        confirmButtonText: '中断生成',
        cancelButtonText: '继续生成',
        type: 'warning'
      }
    )

    abortingGeneration.value = true

    if (workflowModeActive.value && activeWorkflowTaskId.value) {
      await cancelWorkflow(Number(activeWorkflowTaskId.value))
      ElMessage.success('已中断工作流生成')
    } else {
      ElMessage.success('已停止当前生成会话')
    }

    clearAllPollTimers()
    clearProgressState()
    resetGenerationRuntimeState()
  } catch (error: any) {
    if (error !== 'cancel') {
      ElMessage.error(error?.message || '中断失败，请稍后重试')
    }
  } finally {
    abortingGeneration.value = false
  }
}


const handleReset = () => {
  clearAllPollTimers()
  clearProgressState()
  stopAnalysisSingleProgress(true)
  analysisSingleTaskStatus.value = 'PENDING'
  analysisSingleTaskBackendPercent.value = 0
  analysisBatchTaskStatus.value = 'PENDING'
  analysisWorkflowStatus.value = ''
  analysisWorkflowState.value = ''
  intentDetecting.value = false
  intentDetected.value = 'DATA_ANALYSIS'
  intentEffective.value = 'DATA_ANALYSIS'
  intentConfidence.value = 0
  intentOverride.value = ''
  if (detectIntentTimer) {
    window.clearTimeout(detectIntentTimer)
    detectIntentTimer = null
  }

  form.keywords = ''
  form.trainingTopic = ''
  form.techStackRequirements = []
  form.datasetScale = 10
  form.storyStyle = ''
  form.difficultyLevel = 2
  form.estimatedHours = 3
  form.deliverableMode = 'NON_CODE'
  form.numVersions = 1
  form.courseId = courseList.value.length > 0 ? courseList.value[0].id : null
  generatedCase.value = null
  showReviewPanel.value = false
  
  // Workflow Reset
  showWorkflowProgress.value = false
  activeWorkflowTaskId.value = null
  workflowStatus.value = 'pending'
  workflowSteps.value = []
  workflowLogs.value = []
  singleWorkflowReviewSnapshot.value = null
}

const executeRegenerateSingleCase = () => {
  generatedCase.value = null
  const snapshot = lastSingleGenerateSnapshot.value
  if (!snapshot || !snapshot.payload) {
    executeGenerate()
    return
  }

  const shouldUseWorkflowSnapshot = snapshot.type === 'workflow-single'
    || snapshot?.payload?.deliverableMode === 'NON_CODE'

  if (shouldUseWorkflowSnapshot) {
    loading.value = true
    showWorkflowProgress.value = true
    activeWorkflowTaskId.value = null
    workflowStatus.value = 'processing'
    workflowCurrentStage.value = 'INIT'
    workflowSteps.value = []
    workflowLogs.value = []
    workflowError.value = ''
    singleWorkflowReviewSnapshot.value = null

    generateCaseWithWorkflow(clonePayload(snapshot.payload))
      .then((response: any) => {
        const workflowInstanceId = String(response.data)
        activeWorkflowTaskId.value = workflowInstanceId
        saveProgressState({
          generationMode: 'single',
          useWorkflowMode: true,
          workflowInstanceId
        })
        pollWorkflowProgressLoop(workflowInstanceId)
        ElMessage.success('已按上次参数重新发起工作流生成')
      })
      .catch((error: any) => {
        ElMessage.error(error.message || '重新生成失败')
        loading.value = false
        workflowStatus.value = 'error'
        workflowError.value = error.message
      })
    return
  }

  loading.value = true
  showReviewPanel.value = false
  generatedCase.value = null

  const isAnalysisSnapshot = snapshot.type === 'analysis-single'
  if (isAnalysisSnapshot) {
    analysisSingleTaskStatus.value = 'PENDING'
    analysisSingleTaskBackendPercent.value = 0
    startAnalysisSingleProgress()
  }

  const request = isAnalysisSnapshot
    ? generateNonCodeCase(clonePayload(snapshot.payload))
    : generateCase(clonePayload(snapshot.payload))

  request
    .then((response: any) => {
      const taskId = response.data.taskId
      ElMessage.success('已按上次参数重新生成案例')
      saveProgressState({
        generationMode: 'single',
        useWorkflowMode: false,
        singleTaskId: taskId
      })
      pollTaskProgress(taskId)
    })
    .catch((error: any) => {
      ElMessage.error(error.message || '重新生成失败')
      loading.value = false
      stopAnalysisSingleProgress(true)
    })
}

const handleRegenerateSingleCase = () => {
  openGenerationNotice(executeRegenerateSingleCase)
}

const handleEditCase = () => {
  if (!generatedCase.value) return
  router.push(`/teacher/cases/${generatedCase.value.caseId}/edit`)
}

const handlePublish = async () => {
  if (!generatedCase.value) return
  
  try {
    await publishCase(generatedCase.value.caseId)
    ElMessage.success('案例发布成功')
    handleReset()
  } catch (error: any) {
    ElMessage.error(error.message || '案例发布失败')
  }
}

// 检查是否有待审核的案例
const checkPendingCases = async () => {
  const hasOngoingBatch = !!currentBatchTaskId.value && (
    Number(batchGenerationProgress.value?.runningCount || 0) > 0
    || String(batchGenerationProgress.value?.status || '').toUpperCase() === 'RUNNING'
    || Number(batchGenerationProgress.value?.progressPercent || 0) < 100
  )

  if (loading.value || hasOngoingBatch) {
    return
  }

  await refreshPendingCases()
  if (pendingCases.value.length > 0) {
    showReviewPanel.value = true
    ElMessage.info(`您有 ${pendingCases.value.length} 个待审核案例，请先完成审核`)
  }
}

onMounted(() => {
  configPaneWidth.value = clampPaneWidth(PANEL_DEFAULT_WIDTH)
  loadGuidePreference()
  loadCourses()
  loadClasses()
  restoreGenerationProgress().finally(() => {
    checkPendingCases()
  })
  runDetectIntent(true)
})

onUnmounted(() => {
  stopResize()
  clearAllPollTimers()
  stopAnalysisSingleProgress(true)
  if (detectIntentTimer) {
    window.clearTimeout(detectIntentTimer)
    detectIntentTimer = null
  }
})

// 同步useWorkflowMode到form.enableWorkflow
watch(useWorkflowMode, (val) => {
  form.enableWorkflow = val
  // 如果关闭工作流模式，同时重置检查点开关为默认值
  if (!val) {
    form.enableCheckpoints = true
  }
})

watch(() => form.deliverableMode, (mode) => {
  if (mode === 'NON_CODE') {
    useWorkflowMode.value = true
    form.enableWorkflow = true
  }
  if (mode !== 'NON_CODE') {
    intentDetecting.value = false
    intentDetected.value = 'DATA_ANALYSIS'
    intentEffective.value = 'DATA_ANALYSIS'
    intentConfidence.value = 0
    intentOverride.value = ''
    if (detectIntentTimer) {
      window.clearTimeout(detectIntentTimer)
      detectIntentTimer = null
    }
  } else {
    runDetectIntent(true)
  }
}, { immediate: true })

watch(() => form.keywords, () => {
  if (isAnalysisMode.value) {
    runDetectIntent(false)
  }
})

// 监听学生选择变化，更新全选状态
watch(selectedStudents, (val) => {
  if (val.length === 0) {
    selectAll.value = false
    isIndeterminate.value = false
  } else if (val.length === studentList.value.length) {
    selectAll.value = true
    isIndeterminate.value = false
  } else {
    selectAll.value = false
    isIndeterminate.value = true
  }
})

watch(
  () => ({
    batchTaskId: currentBatchTaskId.value,
    runningCount: Number(batchGenerationProgress.value?.runningCount || 0),
    status: String(batchGenerationProgress.value?.status || '').toUpperCase(),
    progressPercent: Number(batchGenerationProgress.value?.progressPercent || 0)
  }),
  ({ batchTaskId, runningCount, status, progressPercent }) => {
    const hasAnyRunning = !!batchTaskId && (
      runningCount > 0
      || status === 'RUNNING'
      || progressPercent < 100
    )

    if (hasAnyRunning && showReviewPanel.value) {
      showReviewPanel.value = false
    }
  },
  { deep: true, immediate: true }
)

watch(loading, (val) => {
  if (!val) {
    stopAnalysisSingleProgress(true)
  }
})
</script>


{
  "name": "tms-integration-tool",
  "version": "0.9.8-beta.3.6",
  "description": "TOS integration tool",
  "main": "main-simple.js",
  "scripts": {
    "dev": "electron .",
    "launcher:ensure:dev": "node automation-launcher/bootstrap.js",
    "launcher:register:dev": "node automation-launcher/register-dev.js --start",
    "launcher:register:dev:startup": "node automation-launcher/register-dev.js --startup --start",
    "launcher:unregister:dev": "node automation-launcher/register-dev.js --unregister",
    "shipping:web:debug:start": "powershell -ExecutionPolicy Bypass -File scripts/start-shipping-web-debug.ps1",
    "shipping:web:debug:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-shipping-web-debug.ps1",
    "clean:update-artifacts": "node scripts/clean-update-artifacts.js",
    "build:backend-runtime": "node scripts/build-backend-runtime.js",
    "verify:renderer-package": "node scripts/verify-renderer-package.js",
    "verify:release-package": "node scripts/verify-release-package.js",
    "write:update-changelog": "node scripts/write-update-changelog.js",
    "write:manual-downloads": "node scripts/write-manual-downloads.js",
    "build:frontend": "node scripts/run-pack-default.js --frontend-only",
    "build": "npm run build:backend-runtime && npm run build:frontend && node ./node_modules/electron-builder/out/cli/cli.js && npm run verify:renderer-package && npm run write:update-changelog && npm run write:manual-downloads && npm run verify:release-package",
    "build:win": "npm run build:backend-runtime && npm run build:frontend && npm run clean:update-artifacts && node ./node_modules/electron-builder/out/cli/cli.js --win --x64 && npm run verify:renderer-package && npm run write:update-changelog && npm run write:manual-downloads && npm run verify:release-package",
    "pack": "node scripts/run-pack-default.js || node scripts/verify-default-pack.js",
    "pack:source": "node scripts/run-pack-source.js || node scripts/verify-source-pack.js"
  },
  "keywords": [
    "TMS",
    "TOS",
    "reports",
    "automation",
    "desktop"
  ],
  "author": "DG Operations",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "com.tomwell.tms",
    "productName": "TOS",
    "artifactName": "TOS.Setup.${version}.${ext}",
    "afterPack": "scripts/after-pack.js",
    "detectUpdateChannel": false,
    "protocols": [
      {
        "name": "TOS Automation Launcher",
        "schemes": [
          "tos"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/shikago8515/TOS/releases/latest/download/"
      }
    ],
    "files": [
      "**/*",
      "dist-frontend/**/*",
      "!recovered-frontend/**/*",
      "!automation-apps/**/*",
      "!browser-plugins/**/*",
      "!external-apps/**/*",
      "!automation-launcher/**/*",
      "!backend-runtime/**/*",
      "!archive/**/*",
      "!.npm-cache/**/*",
      "!dist/**/*",
      "!dist-dnd-fix/**/*",
      "!dist-realtest/**/*",
      "!dist-tms-automation-check/**/*",
      "!dist-*/win-unpacked/**/*",
      "!dist-*/**/app.asar",
      "!dist-test/**/*",
      "!dist-complete/**/*",
      "!dist-auto-page/**/*",
      "!dist-auto-resume/**/*",
      "!dist-first-refresh/**/*",
      "!dist-page-fix/**/*",
      "!dist-excel-append/**/*",
      "!dist-no-dedupe/**/*",
      "!dist-style/**/*",
      "!dist-dual-schema/**/*",
      "!dist-backend-fix/**/*",
      "!dist-trim-construction/**/*",
      "!dist-type-names/**/*",
      "!dist-stability/**/*",
      "!dist-panel-compact/**/*",
      "!dist-source-frontend/**/*",
      "!temp-build-*/**/*",
      "!out/**/*",
      "!release/**/*",
      "!*.exe",
      "!*.log",
      "!electron-builder-debug.log",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.vscode",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": "automation-apps",
        "to": "automation-apps",
        "filter": [
          "**/*",
          "!**/uploads/**/*",
          "!**/runs/**/*",
          "!**/run-artifacts/**/*",
          "!**/playwright-user-data/**/*",
          "!**/*.log",
          "!**/*.stdout.json",
          "!**/*.stderr.json",
          "!**/*.local.json",
          "!**/*.secret.local.json",
          "!**/executor.secret*.json",
          "!**/temp-*.py",
          "!**/*.xlsx"
        ]
      },
      {
        "from": "automation-launcher",
        "to": "automation-launcher",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "browser-plugins",
        "to": "browser-plugins",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "external-apps",
        "to": "external-apps",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-runtime",
        "to": "backend-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../tms-backend",
        "to": "backend",
        "filter": [
          "app_version.py",
          "main.py",
          "requirements.txt",
          "api/**/*",
          "modules/**/*",
          "templates/**/*",
          "utils/**/*",
          "!**/__pycache__/**/*",
          "!uploads/**/*",
          "!tests/**/*",
          "!archive/**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/automation-launcher-installer.nsh"
    }
  }
}

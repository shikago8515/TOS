{
  "private": true,
  "scripts": {
    "check": "node scripts/engineering/run-checks.mjs all",
    "check:quick": "node scripts/engineering/run-checks.mjs quick",
    "check:frontend": "node scripts/engineering/run-checks.mjs frontend",
    "check:backend": "node scripts/engineering/run-checks.mjs backend",
    "check:electron": "node scripts/engineering/run-checks.mjs electron",
    "check:changed": "node scripts/engineering/run-changed-checks.mjs",
    "check:changed:dry-run": "node scripts/engineering/run-changed-checks.mjs --dry-run",
    "check:backend-version": "node scripts/engineering/check-backend-version.mjs",
    "ci:install": "node scripts/engineering/install-ci-deps.mjs",
    "test:version": "node --test scripts/engineering/sync-version.test.mjs",
    "test:server-package": "node --test scripts/engineering/package-server-update.test.mjs",
    "release:updates:pull": "python scripts/release_update_sync.py --pull --limit 300",
    "release:updates:push": "python scripts/release_update_sync.py",
    "release:updates:push:dry-run": "python scripts/release_update_sync.py --dry-run",
    "release:updates:dry-run": "python scripts/release_update_sync.py --pull --limit 300 --dry-run",
    "release:updates:sync-local": "python scripts/release_update_sync.py --sync-local",
    "release:updates:check-local": "python scripts/release_update_sync.py --check-local",
    "release:dry-run": "semantic-release --dry-run",
    "release": "semantic-release",
    "version:set": "node scripts/engineering/sync-version.mjs --set",
    "version:bump": "node scripts/engineering/sync-version.mjs --bump",
    "server:package": "node scripts/engineering/package-server-update.mjs",
    "server:package:dry-run": "node scripts/engineering/package-server-update.mjs --dry-run",
    "dev:frontend": "node scripts/engineering/run-npm.mjs --prefix tms-frontend run dev:hybrid",
    "dev:frontend:server": "node scripts/engineering/run-npm.mjs --prefix tms-frontend run dev:server",
    "dev:frontend:hybrid": "node scripts/engineering/run-npm.mjs --prefix tms-frontend run dev:hybrid",
    "dev:frontend:local": "node scripts/engineering/run-npm.mjs --prefix tms-frontend run dev:local",
    "dev:backend:restart": "node scripts/engineering/restart-local-backend.mjs",
    "preview:frontend": "node scripts/engineering/run-npm.mjs --prefix tms-frontend run preview",
    "dev:electron": "node scripts/engineering/run-npm.mjs --prefix tms-electron-app run dev",
    "cleanup:local:dry-run": "node scripts/engineering/cleanup-local-artifacts.mjs",
    "cleanup:local": "node scripts/engineering/cleanup-local-artifacts.mjs --apply"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "electron-builder": "^26.8.1",
    "semantic-release": "^24.2.9"
  }
}

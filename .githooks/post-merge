#!/usr/bin/env sh

if [ "${TOS_RELEASE_UPDATES_SKIP:-}" = "1" ]; then
  exit 0
fi

if git rev-parse --verify ORIG_HEAD >/dev/null 2>&1; then
  python scripts/release_update_sync.py --range "$(git rev-parse ORIG_HEAD)..HEAD" --event merge --quiet >/dev/null 2>&1 || true
else
  python scripts/release_update_sync.py --commit HEAD --event merge --quiet >/dev/null 2>&1 || true
fi
